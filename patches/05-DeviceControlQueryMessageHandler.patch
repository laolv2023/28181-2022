+    /**
+     * 处理PTZ精准控制命令
+     * <p>
+     * 来源: 改造项7, 设计文档第10.1节, 2022版A.2.3.1.11
+     * 规范要求: 2022版新增PTZ精准控制, XML元素名 PTzPrecisectrl
+     * XML结构示例:
+     * <pre>
+     * &lt;PTzPrecisectrl&gt;
+     *   &lt;Pan&gt;...&lt;/Pan&gt;
+     *   &lt;Tilt&gt;...&lt;/Tilt&gt;
+     *   &lt;Zoom&gt;...&lt;/Zoom&gt;
+     * &lt;/PTzPrecisectrl&gt;
+     * </pre>
+     */
+    private void handlePtzPreciseCmd(CommonGBChannel channel, Element rootElement, SIPRequest request, DeviceControlType type) {
+        if (channel.getDataType() != ChannelDataType.GB28181) {
+            log.warn("[deviceControl-PTzPrecisectrl] 只支持国标的PTZ精准控制, 通道ID: {}", channel.getGbId());
+            try {
+                responseAck(request, Response.FORBIDDEN, "");
+            } catch (SipException | InvalidArgumentException | ParseException e) {
+                log.error("[命令发送失败] 错误信息: {}", e.getMessage());
+            }
+            return;
+        }
+        Device device = deviceService.getDevice(channel.getDataDeviceId());
+        if (device == null) {
+            log.warn("[deviceControl-PTzPrecisectrl] 通道所属设备不存在, 通道ID: {}", channel.getGbId());
+            try {
+                responseAck(request, Response.NOT_FOUND, "device not found");
+            } catch (SipException | InvalidArgumentException | ParseException e) {
+                log.error("[命令发送失败] 错误信息: {}", e.getMessage());
+            }
+            return;
+        }
+        // 解析PTZ精准控制参数
+        Element ptzPreciseElement = rootElement.element(type.getVal());
+        String pan = ptzPreciseElement != null ? getText(ptzPreciseElement, "Pan") : null;
+        String tilt = ptzPreciseElement != null ? getText(ptzPreciseElement, "Tilt") : null;
+        String zoom = ptzPreciseElement != null ? getText(ptzPreciseElement, "Zoom") : null;
+        log.info("[deviceControl] 命令: PTZ精准控制, 设备: {}({}), 通道: {}, Pan: {}, Tilt: {}, Zoom: {}",
+                device.getName(), device.getDeviceId(), channel.getGbId(), pan, tilt, zoom);
+        // 向设备下发 PTZ 精准控制 SIP 命令
+        if (channel != null && channel.getDeviceId() != null) {
+            try {
+                cmder2022.ptzPreciseCmd(device, channel.getGbId(),
+                        pan != null ? Double.parseDouble(pan) : 0,
+                        tilt != null ? Double.parseDouble(tilt) : 0,
+                        zoom != null ? Double.parseDouble(zoom) : 0);
+            } catch (Exception e) {
+                log.warn("[命令转发] PTZ精准控制下发失败: {}", e.getMessage());
+            }
+        }
+        try {
+            responseAck(request, Response.OK);
+        } catch (SipException | InvalidArgumentException | ParseException e) {
+            log.error("[命令发送失败] PTZ精准控制: {}", e.getMessage());
+        }
+    }
