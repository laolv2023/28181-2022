<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!-- ================================================================ -->
<!-- 测试用例: A5.2-01                                                 -->
<!-- 测试名称: PTZ精准状态查询                                         -->
<!-- 来源: 改造项13, GB/T 28181-2022 附录A.2.4.1.5                     -->
<!-- 测试场景: 模拟WVP发送PTZ精准状态查询MESSAGE,                      -->
<!--           XML包含 CmdType=PTzPreciseStatusQuery                  -->
<!--           响应包含 Pan/Tilt/Zoom 三个浮点状态值                   -->
<!-- 测试模式: UAC                                                    -->
<!-- 说明: 验证项:                                                    -->
<!--   1. MESSAGE方法,Content-Type=Application/MANSCDP+xml            -->
<!--   2. CmdType=PTzPreciseStatusQuery(注意首字母P小写T大写z小写)    -->
<!--   3. 响应XML包含 Pan/Tilt/Zoom 三个浮点字段                      -->
<!--   4. 字段单位: Pan/Tilt 单位为度,Zoom 为倍率                     -->
<!-- 改造项13要点: PTZ精准状态查询为2022版新增,与A4.1-01精准控制      -->
<!--             命令对应,实现PTZ闭环位置反馈                        -->
<!-- GB/T 28181-2022 A.2.4.1.5 定义 PTzPreciseStatusQuery 查询命令    -->
<!-- ================================================================ -->

<scenario name="query_ptz_precise_status">

  <!-- 步骤1: WVP向设备发送PTZ精准状态查询 MESSAGE -->
  <send retrans="500">
    <![CDATA[
      MESSAGE sip:34020000001320000001@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=z9hG4bK[callId]
      From: <sip:34020000002000000001@[local_ip]:[local_port]>;tag=[pid]SIPpTagA5201[callNumber]
      To: <sip:34020000001320000001@[remote_ip]:[remote_port]>
      Call-ID: [call_id]
      CSeq: [cseq] MESSAGE
      Max-Forwards: 70
      User-Agent: WVP-Test-Simulator-A5201
      Content-Type: Application/MANSCDP+xml
      Content-Length: [len]

      <?xml version="1.0" encoding="UTF-8"?>
      <Query>
      <CmdType>PTzPreciseStatusQuery</CmdType>
      <SN>1</SN>
      <DeviceID>34020000001320000001</DeviceID>
      </Query>
    ]]>
  </send>

  <!-- 步骤2: 接收设备的 200 OK 响应 -->
  <recv response="200" rtd="true">
  </recv>

  <!-- 步骤3: 接收设备返回的PTZ精准状态 Notify MESSAGE -->
  <recv request="MESSAGE" rtd="true">
    <action>
      <ereg regexp="<Pan>10\.5</Pan>" search_in="body" assign_to="pan_val" />
      <ereg regexp="<Tilt>20\.3</Tilt>" search_in="body" assign_to="tilt_val" />
      <ereg regexp="<Zoom>1\.5</Zoom>" search_in="body" assign_to="zoom_val" />
    </action>
  </recv>

  <!-- 步骤4: WVP返回 200 OK 表示已收到查询响应 -->
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <RecvRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

</scenario>
