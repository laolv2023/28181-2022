<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!-- ================================================================ -->
<!-- 测试用例: B3-12                                                   -->
<!-- 测试名称: 强制关键帧合规性                                        -->
<!-- 来源: 设计文档第14.3节, GB/T 28181-2022 附录A.2.3.1.4            -->
<!-- 测试场景: 验证强制I帧(IFame)控制命令格式                          -->
<!--           用于触发设备立即编码关键帧,常用于码流切换/录制起始      -->
<!-- 测试模式: UAC                                                    -->
<!-- 说明: 验证项:                                                    -->
<!--   1. MESSAGE方法,Content-Type=Application/MANSCDP+xml            -->
<!--   2. CmdType=DeviceControl                                       -->
<!--   3. IFame 元素存在(空元素表示触发立即I帧)                       -->
<!--   4. 设备返回 200 OK 表示已触发关键帧                            -->
<!-- GB/T 28181-2022 A.2.3.1.4 强制I帧 IFame:                         -->
<!--   - 主要用于H.264/H.265码流的随机访问点生成                      -->
<!--   - 应用于:拉流前预生成I帧,录像分段起始,故障重连恢复           -->
<!-- 注意: 规范中IFame首字母为I(非IFrame),需严格按规范字段名          -->
<!-- ================================================================ -->

<scenario name="ctrl_b3_12_i_frame">

  <!-- 步骤1: WVP向设备发送强制关键帧控制 MESSAGE -->
  <send retrans="500">
    <![CDATA[
      MESSAGE sip:34020000001320000001@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=z9hG4bK[callId]
      From: <sip:34020000002000000001@[local_ip]:[local_port]>;tag=[pid]SIPpTagB312[callNumber]
      To: <sip:34020000001320000001@[remote_ip]:[remote_port]>
      Call-ID: [call_id]
      CSeq: [cseq] MESSAGE
      Max-Forwards: 70
      User-Agent: WVP-Test-Simulator-B312
      Content-Type: Application/MANSCDP+xml
      Content-Length: [len]

      <?xml version="1.0" encoding="UTF-8"?>
      <Notify>
      <CmdType>DeviceControl</CmdType>
      <SN>1</SN>
      <DeviceID>34020000001320000001</DeviceID>
      <IFame></IFame>
      </Notify>
    ]]>
  </send>

  <!-- 步骤2: 接收设备的 200 OK 响应(已触发I帧编码) -->
  <recv response="200" rtd="true">
  </recv>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <RecvRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

</scenario>
