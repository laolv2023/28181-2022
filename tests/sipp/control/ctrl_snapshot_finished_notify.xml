<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!-- ================================================================ -->
<!-- 测试用例: A4.2-02                                                 -->
<!-- 测试名称: 抓拍图像传输完成通知                                    -->
<!-- 来源: 改造项15, spec_2022.txt 行2516                              -->
<!-- 测试场景: 模拟设备向WVP发送抓拍完成Notify MESSAGE,                -->
<!--           XML包含:                                                -->
<!--             - CmdType=uploadsnapshotFinished                    -->
<!--             - sessionID=123(与抓拍命令中sessionID对应)          -->
<!-- 测试模式: UAC (设备侧主动发送Notify 给 WVP)                       -->
<!-- 说明: 验证项:                                                    -->
<!--   1. MESSAGE方法,Content-Type=Application/MANSCDP+xml            -->
<!--   2. CmdType=uploadsnapshotFinished(注意全小写upload前缀)        -->
<!--   3. sessionID 与 A4.1-05 抓拍配置一致                           -->
<!--   4. WVP返回 200 OK 表示已收到通知                               -->
<!-- 改造项15要点: 抓拍完成后设备主动通知WVP,触发图像下载流程         -->
<!-- spec_2022.txt 行2516 定义 uploadsnapshotFinished 命令类型         -->
<!-- ================================================================ -->

<scenario name="ctrl_snapshot_finished_notify">

  <!-- 步骤1: 设备向WVP发送抓拍完成通知 MESSAGE -->
  <send retrans="500">
    <![CDATA[
      MESSAGE sip:34020000002000000001@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=z9hG4bK[callId]
      From: <sip:34020000001320000001@[local_ip]:[local_port]>;tag=[pid]SIPpTagA4202[callNumber]
      To: <sip:34020000002000000001@[remote_ip]:[remote_port]>
      Call-ID: [call_id]
      CSeq: [cseq] MESSAGE
      Max-Forwards: 70
      User-Agent: Device-Simulator-A4202
      Content-Type: Application/MANSCDP+xml
      Content-Length: [len]

      <?xml version="1.0" encoding="UTF-8"?>
      <Notify>
      <CmdType>uploadsnapshotFinished</CmdType>
      <SN>1</SN>
      <DeviceID>34020000001320000001</DeviceID>
      <sessionID>123</sessionID>
      </Notify>
    ]]>
  </send>

  <!-- 步骤2: 接收WVP的 200 OK 响应 -->
  <recv response="200" rtd="true">
  </recv>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <RecvRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>

</scenario>
